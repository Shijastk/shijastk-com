# ---- Supabase (create a project at https://supabase.com → Project Settings) ----
# Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Settings → Database → Connection string → URI (use the pooled 6543 port for serverless)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres"

# ---- GitHub integration ----
NEXT_PUBLIC_GITHUB_USERNAME="Shijastk"
NEXT_PUBLIC_GITHUB_JOIN_YEAR="2022"
# Optional: a classic PAT (public_repo scope) raises the API rate limit for sync.
GITHUB_TOKEN=""

# ---- App ----
# Local dev uses localhost. In PRODUCTION you MUST set this to the canonical
# www host, or canonical tags, og:url, sitemap.xml <loc>s and the robots.txt
# Sitemap line will all point at localhost and Google won't index the site:
#   NEXT_PUBLIC_SITE_URL="https://www.shijastk.in"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# Shared secret protecting /api/revalidate and /api/github/sync (any random string).
REVALIDATE_SECRET="change-me-to-a-long-random-string"

# ---- Object storage for admin-uploaded project images (S3-compatible) ----
# Works with Backblaze B2 or Cloudflare R2. OPTIONAL: without these, the admin
# image fields fall back to pasting plain URLs. The bucket can stay PRIVATE —
# objects are streamed via the /api/files proxy route. Use a bucket-scoped key.
R2_ENDPOINT="https://s3.us-east-005.backblazeb2.com"
R2_REGION="us-east-005"
R2_ACCESS_KEY_ID="your-key-id"
R2_SECRET_ACCESS_KEY="your-application-key"
R2_BUCKET="your-bucket-name"
